{
  "name": "bytescookies",
  "version": "1.0.0",
  "description": "Cookie management web application",
  "main": "server/index.js",
  "scripts": {
    "dev": "npm run dev:server & npm run dev:client",
    "dev:client": "cd client && npm run dev",
    "dev:server": "ts-node-dev --respawn --transpile-only server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "tsc",
    "start": "node dist/server/index.js",
    "check": "npm run check:client && npm run check:server",
    "check:client": "cd client && npm run check",
    "check:server": "tsc --noEmit",
    "predeploy": "npm run build-landing",
    "deploy": "gh-pages -d landing-page",
    "build-landing": "node scripts/build-landing.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/themes": "^2.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "react-router-dom": "^6.30.0",
    "tailwind-merge": "^2.2.1",
    "uuid": "^9.0.1",
    "zod": "^3.24.3"
  },
  "overrides": {
    "postcss": "^8.4.31",
    "semver": "^7.5.3",
    "word-wrap": "^1.2.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/chai": "^5.2.1",
    "@types/chrome": "^0.0.315",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@types/node-fetch": "^2.6.12",
    "@types/react": "^19.1.2",
    "@types/uuid": "^9.0.8",
    "chai": "^5.2.0",
    "cpy-cli": "^5.0.0",
    "fs-extra": "^11.3.0",
    "gh-pages": "^6.3.0",
    "mkdirp": "^3.0.1",
    "mocha": "^11.1.0",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
